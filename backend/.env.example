# Server
PORT=4000

# Database — set either DATABASE_URL or DB_* (password required for PostgreSQL SCRAM auth)
# Option A: full URL
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/doganconsult

# Option B: components (password configured in .env)
DB_USER=doganconsult
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=doganconsult

# Admin API token (also used as legacy single-password login)
ADMIN_PASSWORD=changeme

# JWT secret for portal employee/admin tokens (defaults to ADMIN_PASSWORD if unset)
# JWT_SECRET=your-jwt-secret-here

# First portal admin seed (optional; used by npm run portal:seed when no users exist)
# PORTAL_ADMIN_EMAIL=admin@doganconsult.com
# PORTAL_ADMIN_NAME=Portal Admin
# PORTAL_ADMIN_PASSWORD=changeme
